# Copy this file to .env and fill in your values:
#   PowerShell: Copy-Item .env.example .env
#   Git Bash:   cp .env.example .env
#
# .env is gitignored — never commit real credentials.

# PostgreSQL credentials
# On Windows, DATABASE_USER defaults to your Windows username if not set.
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432

# Override the database base name (optional).
# Defaults to the project folder name (e.g. folder "my-app" → "my_app").
# DATABASE_NAME=my_custom_name

# Rails thread pool size (default: 5)
# RAILS_MAX_THREADS=5

# Transactional email (Resend) — optional in development (letter_opener is the default)
# RESEND_API_KEY=re_xxx
# MAIL_FROM=App <noreply@notification.example.com>
# MAIL_REPLY_TO=hello@example.com

# Public host for mailer links and sitemap (production/staging)
# APP_HOST=example.com

# Inbound email webhook secret (used by Cloudflare Worker → POST /webhooks/inbound_email)
# INBOUND_EMAIL_WEBHOOK_SECRET=
