#!/usr/bin/env ruby
# frozen_string_literal: true

# Usage:
#   ruby bin/rails runner bin/setup_credentials KEY_NAME VALUE
#   ruby bin/rails runner bin/setup_credentials resend_api_key re_xxx
#   ruby bin/rails runner bin/setup_credentials inbound_email_webhook_secret abc123

require "fileutils"
require "active_support/encrypted_file"

key_name  = ARGV[0]
key_value = ARGV[1]

if key_name.nil? || key_value.nil?
  puts "Usage: ruby bin/rails runner bin/setup_credentials KEY_NAME VALUE"
  puts ""
  puts "Examples:"
  puts "  ruby bin/rails runner bin/setup_credentials resend_api_key re_xxx"
  puts "  ruby bin/rails runner bin/setup_credentials inbound_email_webhook_secret abc123"
  exit 1
end

credentials_dir = Rails.root.join("config/credentials")
FileUtils.mkdir_p(credentials_dir)

key_path = credentials_dir.join("#{Rails.env}.key")
enc_path = credentials_dir.join("#{Rails.env}.yml.enc")

unless key_path.exist?
  key = SecureRandom.hex(16)
  File.write(key_path, key)
  puts "Generated new #{Rails.env}.key"
end

enc = ActiveSupport::EncryptedFile.new(
  content_path: enc_path,
  key_path: key_path,
  env_key: "RAILS_MASTER_KEY",
  raise_if_missing_key: true
)

existing = begin
  enc.read
rescue ActiveSupport::MessageEncryptor::InvalidMessage, Errno::ENOENT
  ""
end

if existing.match?(/^#{Regexp.escape(key_name)}:/)
  updated = existing.gsub(/^#{Regexp.escape(key_name)}:.*$/, "#{key_name}: #{key_value}")
  enc.write(updated)
  puts "Updated #{key_name} in config/credentials/#{Rails.env}.yml.enc"
else
  enc.write(existing.strip + "\n#{key_name}: #{key_value}\n")
  puts "Added #{key_name} to config/credentials/#{Rails.env}.yml.enc"
end
